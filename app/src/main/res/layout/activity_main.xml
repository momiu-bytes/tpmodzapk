<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#202124">

    <!-- LOGIN SCREEN -->
    <LinearLayout
        android:id="@+id/login_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="visible">

        <!-- Stylized Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TP×MD"
            android:textColor="#FFFFFF"
            android:textSize="56sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAG TP×MDUC"
            android:textColor="#00FFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp"
            android:gravity="center" />

        <!-- Card Container with Cyan Border -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cyan_border"
            android:padding="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhập mã kích hoạt (KEY)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <!-- KEY input field -->
            <EditText
                android:id="@+id/et_key"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_field"
                android:hint="KEY"
                android:textColorHint="#66FFFFFF"
                android:textColor="#FFFFFF"
                android:inputType="text"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:maxLength="10"
                android:singleLine="true" />

            <!-- Login Button -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="OK"
                android:textColor="#00FFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- CONTROL SCREEN (AFTER LOGIN) -->
    <LinearLayout
        android:id="@+id/control_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Logo top -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TP×MD"
            android:textColor="#FFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAG TP×MDUC"
            android:textColor="#00FFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:gravity="center" />

        <!-- Status Card with Cyan Border -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cyan_border"
            android:padding="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="16dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BẢNG ĐIỀU KHIỂN NÚT NỔI"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Status Indicator -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nút nổi đang tắt"
                android:textColor="#FF5555"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- Toggle Service Button -->
            <Button
                android:id="@+id/btn_toggle_service"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="BẬT NÚT NỔI"
                android:textColor="#00FFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Request Permission Button (hidden if granted) -->
            <Button
                android:id="@+id/btn_request_permission"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_button_cyan_solid_selector"
                android:text="CẤP QUYỀN VẼ TRÊN ỨNG DỤNG KHÁC"
                android:textColor="#202124"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Help instructions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sau khi bật nút nổi, bạn có thể thoát ra màn hình chính.\nNhấn vào nút nổi để điều khiển lag."
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:lineSpacingMultiplier="1.2" />

    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_cyan_border"
    android:orientation="vertical"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <!-- HEADER: Title and Control Buttons -->
    <RelativeLayout
        android:id="@+id/panel_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAG CONTROL"
            android:textColor="#00FFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <!-- Minimize & Close Buttons on the Right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center">

            <!-- Size Resize Button -->
            <TextView
                android:id="@+id/btn_resize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="Size"
                android:textColor="#00FFFF"
                android:textSize="10dp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <!-- Minimize Button -->
            <TextView
                android:id="@+id/btn_minimize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="—"
                android:textColor="#00FFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <!-- Close Button -->
            <TextView
                android:id="@+id/btn_close_panel"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="X"
                android:textColor="#FF5555"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </RelativeLayout>

    <!-- DISPLAY SCREEN (7 Numbers) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_field"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/tv_display"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="_______"
            android:textColor="#66FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

    </FrameLayout>

    <!-- KEYBOARD GRID -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Row 1: 1, 2, 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/key_1"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_2"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_3"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Row 2: 4, 5, 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/key_4"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="4"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_5"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="5"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_6"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="6"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Row 3: 7, 8, 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/key_7"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="7"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_8"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="8"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_9"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="9"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Row 4: C, 0, DEL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/key_clear"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="C"
                android:textColor="#FF5555"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_0"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/key_del"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:background="@drawable/bg_button_cyan_selector"
                android:text="DEL"
                android:textColor="#00FFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- SUBMIT BUTTON -->
    <Button
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_button_cyan_solid_selector"
        android:text="OK"
        android:textColor="#202124"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#4D000000"> <!-- Dark Ripple -->
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape>
                    <solid android:color="#CC00FFFF" /> <!-- Lighter Cyan on press -->
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape>
                    <solid android:color="#00FFFF" /> <!-- Solid Cyan background -->
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
